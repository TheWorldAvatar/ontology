        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>Broken Underground Utility</rdfs:label>
    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/BulgeOnGround -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/BulgeOnGround">
        <rdfs:subClassOf rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/AlertOrWarningSign"/>
        <rdfs:comment>A raised area of land indicating ground movement or subsurface pressure.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>Bulge On Ground</rdfs:label>
    </owl:Class>
    


