    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/usedLogistics">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Response"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ResponseLogistics"/>
        <rdfs:comment>Denotes the logistics used during the response to a landslide.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>used Logistics</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/warnsAbout -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/warnsAbout">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideAlertOrWarning"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/WarningSign"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:comment>A relationship between a Landslide Alert/Warning and the actual landslide event it refers to.</rdfs:comment>
        <rdfs:comment>Indicates the landslide that the warning sign is about.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>warns About</rdfs:label>
        <rdfs:label>warns about</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.w3.org/2006/time#hasBeginning -->


    <owl:ObjectProperty rdf:about="http://www.w3.org/2006/time#hasBeginning">
        <rdfs:domain rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Instant"/>
        <rdfs:isDefinedBy rdf:resource="https://www.w3.org/2006/time"/>
