<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.theworldavatar.com/kg/ontowildfire/"
     xml:base="http://www.theworldavatar.com/kg/ontowildfire/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:ontowildfire="http://www.theworldavatar.com/kg/ontowildfire/">
    <owl:Ontology rdf:about="http://www.theworldavatar.com/kg/ontowildfire/">
        <dc:date>09 March 2026</dc:date>
        <gitCommitHash>c0599beca8df55873a1ab061dee64e52c510c6a0</gitCommitHash>
        <rdfs:comment>OntoLandslide is an ontology developed to represent landslide hazard</rdfs:comment>
        <owl:versionInfo>1</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/date -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/gitCommitHash -->


    <owl:AnnotationProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/gitCommitHash"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.ontology-of-units-of-measure.org/resource/om-2/hasUnit -->


    <owl:ObjectProperty rdf:about="http://www.ontology-of-units-of-measure.org/resource/om-2/hasUnit">
        <rdfs:domain rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Measure"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Unit"/>
        <rdfs:isDefinedBy rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/"/>
        <rdfs:label>has unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/actionTaken -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/actionTaken">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Response"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ResponseAction"/>
        <rdfs:comment>Specifies the actions taken in response to a landslide.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>action Taken</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/affects -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/affects">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Hazard"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/EnvironmentalComponent"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/InfrastructureComponent"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>A relationship between a landslide and affected entities.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>affects</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/causesDamageOf -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/causesDamageOf">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Hazard"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:comment>This property links a hazard to the quantity representing the damage it causes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/causesEvacuationOf -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/causesEvacuationOf">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Hazard"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:comment>This property associates a hazard with the quantity representing the number of evacuations it causes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>causes Evacuation Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/causesLossOfLifeOf -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/causesLossOfLifeOf">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Hazard"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:comment>This property links a hazard to the quantity representing the loss of life it causes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>causes Loss Of Life Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/containsProperty -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/containsProperty">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Dataset"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Property"/>
        <rdfs:comment>An object property that indicates that a LandslideDataset contains a specific property related to landslide measurements.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>contains Property</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/currentAlertOrWarningSign -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/currentAlertOrWarningSign">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideSpot"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/WarningSign"/>
        <rdfs:comment>Associates a landslide spot with its current warning sign.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>current Warning Sign</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/currentWarning -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/currentWarning">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideArea"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideAlertOrWarning"/>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>current warning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/endangersOf -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/endangersOf">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Hazard"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:comment>This property connects a hazard to the quantity representing the entities it endangers.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>endangers Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasAffectedArea -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasAffectedArea">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/InfrastructureComponent"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Area"/>
        <rdfs:comment>A relationship between an affected Infrastructure Component and the corresponding area affected.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has affected area</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasAlertOrWarningHistory -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasAlertOrWarningHistory">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideSpot"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LanslideArea"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideAlertOrWarningHistory"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideWarningHistory"/>
        <rdfs:comment>A relationship between a Landslide Area and its collection of previous landslide warnings and alerts.</rdfs:comment>
        <rdfs:comment>Links a landslide spot to its warning history.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Warning History</rdfs:label>
        <rdfs:label>has historical warning</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasCausalFactor -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasCausalFactor">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/CausalFactor"/>
        <rdfs:comment>Identifies the causal factor responsible for a landslide.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Causal Factor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasFileUrl -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasFileUrl">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ShapeFile"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/FileUrl"/>
        <rdfs:comment>Points to the URL of the shapefile.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has File Url</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasGeometry -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasGeometry">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:comment>Indicates the geometric representation of a location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Geometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasLandslideHistory -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasLandslideHistory">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideHistory"/>
        <rdfs:comment>Connects a location to its associated landslide history.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Landslide History</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasLikelihood -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasLikelihood">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/RiskLevel"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Likelihood"/>
        <rdfs:comment>A relationship between a risk level and the underlying likelihood.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has likelihood</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasLocation -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasLocation">
        <rdfs:domain rdf:resource="http://sweetontology.net/phen/Event"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Event"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://sweetontology.net/phen/Event"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/LandslideArea"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/LandslideForecast"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:comment>A relationship between a (forecasted) event and its geospatial location.</rdfs:comment>
        <rdfs:comment>A relationship between an event and a geographic location</rdfs:comment>
        <rdfs:comment>Links an event to the geographic location where it occurred.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Location</rdfs:label>
        <rdfs:label>has location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasMeasurement -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasMeasurement">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Property"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Measurement"/>
        <rdfs:comment>An object property that connects a property to the corresponding measurement data.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Measurement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasMeasurementInterval -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasMeasurementInterval">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Property"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Interval"/>
        <rdfs:comment>An object property that associates a property with a specific time interval during which measurements are taken.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Measurement Interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasMonetaryValue -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasMonetaryValue">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Impact"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/AmountOfMoney"/>
        <rdfs:comment>A relationship between an Impact and the quantification of its cumulative effects in monetary terms.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has monetary value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasPotentialImpact -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasPotentialImpact">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/RiskLevel"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/PotentialImpact"/>
        <rdfs:comment>A relationship between a risk level and the underlying impact potential.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has potential impact</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasResponse -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasResponse">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Response"/>
        <rdfs:comment>Associates a landslide event with the response taken.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Response</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasRiskLevel -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasRiskLevel">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideForecast"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/RiskLevel"/>
        <rdfs:comment>A relationship between a landslide forecast and its anticipated risk.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has risk level</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasSeverity -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasSeverity">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideAlertOrWarning"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/WarningSign"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Severity"/>
        <rdfs:comment>A relationship between a Landslide Alert/Warning and its severity.</rdfs:comment>
        <rdfs:comment>Links a warning sign to its severity level.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Severity</rdfs:label>
        <rdfs:label>has severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasShapeFile -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasShapeFile">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ShapeFile"/>
        <rdfs:comment>Refers to the shapefile associated with a specific location.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Shape File</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasStage -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasStage">
        <rdfs:domain rdf:resource="http://sweetontology.net/phen/Event"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Stage"/>
        <rdfs:comment>This property describes the different phases or stages that a hazard event undergoes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Stage</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasTimeInterval -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasTimeInterval">
        <rdfs:domain rdf:resource="http://sweetontology.net/phen/Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:comment>A relationship between an event and the time interval associated with the duration of the event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has TimeInterval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasTimeSeries -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasTimeSeries">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideHistory"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideWarningHistory"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/TimeSeries"/>
        <rdfs:comment>Associates landslide history with a time series of data points.</rdfs:comment>
        <rdfs:comment>Associates landslide warning history with a time series of warning data.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Time Series</rdfs:label>
        <rdfs:label>has Warning Time Series</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasValue -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasValue">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Measurement"/>
        <rdfs:range rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Measure"/>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has value</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/indicatesQuantityOf -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/indicatesQuantityOf">
        <rdfs:domain rdf:resource="http://www.ontology-of-units-of-measure.org/resource/om-2/Quantity"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/EnvironmentalComponent"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/InfrastructureComponent"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/Population"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>This property associates a quantity with the environmental component, population, or infrastructure component it indicates.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>indicates Quantity Of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/isBasedOn -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/isBasedOn">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideAlertOrWarning"/>
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideForecastModel"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/LandslideForecast"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/LandslideDataset"/>
                    <rdf:Description rdf:about="http://www.theworldavatar.com/kg/ontowildfire/MeteorologicalDataset"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>A computational model that predicts potential landslide events based on landslide, meteorological, and geographic data.</rdfs:comment>
        <rdfs:comment>An object property that specifies that a LandslideDataset is derived from either a LandslideForecastModel or a MeteorologicalDataset.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>is Based On</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/isMeasuredBy -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/isMeasuredBy">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Property"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Sensor"/>
        <rdfs:comment>An object property that links a property to the sensor responsible for measuring it.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>is Measured By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/isProducedBy -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/isProducedBy">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ShapeFile"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Organization"/>
        <rdfs:comment>Identifies the organization that produced a shapefile.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>is Produced By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/occurredIn -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/occurredIn">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:comment>Links an landslide occurrence to the location where it took place</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/occursOn -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/occursOn">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Slope/Soil/GeologicalLayer"/>
        <rdfs:comment>Indicates the slope, soil, or geological layer on which a landslide occurs.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>occurs On</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/precededBy -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/precededBy">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Stage"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Stage"/>
        <rdfs:comment>This property indicates a temporal relationship where one event or stage occurs before another.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>preceded By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/reportedBy">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/WarningSign"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Person"/>
        <rdfs:comment>Refers to the person who reported a warning sign.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>reported By</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/responseBy -->


    <owl:ObjectProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/responseBy">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Response"/>
        <rdfs:range rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ResponseDepartment"/>
        <rdfs:comment>Refers to the department responsible for the response.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>response By</rdfs:label>
    </owl:ObjectProperty>
    


