        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Lat</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasLon -->


    <owl:DatatypeProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasLon">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <rdfs:comment>This property represents the longitude coordinate of a specific landslide location, expressed as a floating-point number.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Lon</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/hasVelocity -->


    <owl:DatatypeProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasVelocity">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Landslide"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>Represents the speed at which the landslide moves, with the value being a float.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>has Velocity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/lastUpdateOn -->


    <owl:DatatypeProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/lastUpdateOn">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ShapeFile"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>This property represents the timestamp of the most recent update related to the landslide situation.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>last Update On</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/measurementEndtime -->


    <owl:DatatypeProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/measurementEndtime">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Property"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A data property that defines the ending time of a measurement event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>measurement Endtime</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/measurementStarttime -->


