        <rdfs:label>Air</rdfs:label>
    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/AlertOrWarningSign -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/AlertOrWarningSign">
