        <rdfs:range rdf:resource="https://www.theworldavatar.com/kg/ontolandslide/Landslide"/>
        <rdfs:comment>A hazard initiates or contributes to the occurrence of another hazard</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>triggers</rdfs:label>
    </owl:ObjectProperty>
    


