    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/ArealInfrastructure -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/ArealInfrastructure">
        <rdfs:subClassOf rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/InfrastructureComponent"/>
        <rdfs:comment>Areal installations and land-uses.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>Areal infrastructure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/BrokenUndergroundUtility -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/BrokenUndergroundUtility">
        <rdfs:subClassOf rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/AlertOrWarningSign"/>
