    <owl:DatatypeProperty rdf:about="http://www.theworldavatar.com/kg/ontowildfire/hasLat">
        <rdfs:domain rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/Location"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
