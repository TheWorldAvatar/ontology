        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>Causal Factor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/CommercialInfrastructure -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/CommercialInfrastructure">
        <rdfs:subClassOf rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ArealInfrastructure"/>
        <rdfs:comment>Material infrastructure in form of commercial buildings.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>CommercialArea</rdfs:label>
    </owl:Class>
    


    <!-- http://www.theworldavatar.com/kg/ontowildfire/Community -->


    <owl:Class rdf:about="http://www.theworldavatar.com/kg/ontowildfire/Community">
        <rdfs:subClassOf rdf:resource="http://www.theworldavatar.com/kg/ontowildfire/ResponseDepartment"/>
