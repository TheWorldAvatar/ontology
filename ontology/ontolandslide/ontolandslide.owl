        <rdfs:comment>A data property that defines the starting time of a measurement event.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.theworldavatar.com/kg/ontolandslide"/>
        <rdfs:label>measurement Starttime</rdfs:label>
    </owl:DatatypeProperty>
    


